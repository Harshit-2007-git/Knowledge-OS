# ============================================================
# Enterprise AI Knowledge OS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Application ----
APP_NAME=Knowledge OS
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
API_V1_PREFIX=/api/v1

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ---- MySQL Database ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=knowledge_os
MYSQL_PASSWORD=change_me_in_production
MYSQL_DATABASE=knowledge_os_db
MYSQL_ROOT_PASSWORD=root_change_me

# Constructed by the app:
# DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}

# ---- JWT Authentication ----
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- ChromaDB ----
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data

# ---- Ollama (LLM) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_TIMEOUT=120
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# ---- OpenAI-Compatible (future) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ---- Embeddings ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.txt,.md,.docx

# ---- Rate Limiting ----
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
